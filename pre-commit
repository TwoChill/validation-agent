#!/usr/bin/env bash
# pre-commit — validation-agent git hook
# Runs validator.py against every staged Python file before each commit.
# Exit codes from validator.py: 0=pass  1=warnings  2=critical
# This hook: prompts the user on warnings, blocks on critical failures.
#
# Install: copy or symlink this file to .git/hooks/pre-commit and chmod +x
# The install.sh script does this automatically.

set -eo pipefail

# ── Locate the agent directory ──────────────────────────────────────────────
# Search order:
#   1. $VALIDATION_AGENT_DIR  — explicit override (same var install.sh uses)
#   2. $HOME/agents/validation-agent — default install location
#   3. dirname of this script's real path — works when hook is symlinked from the repo
AGENT_DIR=""
_self_dir="$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "$0")")"
for _candidate in \
    "${VALIDATION_AGENT_DIR:-}" \
    "$HOME/agents/validation-agent" \
    "$_self_dir"
do
    [ -n "$_candidate" ] || continue
    if [ -f "$_candidate/validator.py" ]; then
        AGENT_DIR="$_candidate"
        break
    fi
done

if [ -z "$AGENT_DIR" ]; then
    echo "[pre-commit] validation-agent not found — skipping validation." >&2
    exit 0  # fail-open: don't block commits when validator is missing
fi

VALIDATOR="$AGENT_DIR/validator.py"

# ── Get staged Python files ──────────────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0  # nothing to check
fi

# ── Run validation ───────────────────────────────────────────────────────────
CRITICAL_COUNT=0
WARN_COUNT=0
PASS_COUNT=0
CRITICAL_LIST=""
WARN_LIST=""

while IFS= read -r file; do
    [ -f "$file" ] || continue

    printf "[pre-commit] Checking %s ...\n" "$file" >&2

    set +e
    CLAUDE_TOOL_INPUT_FILE_PATH="$file" python3 "$VALIDATOR" 2>&1
    RC=$?
    set -e

    case $RC in
        0) PASS_COUNT=$((PASS_COUNT + 1)) ;;
        1) WARN_COUNT=$((WARN_COUNT + 1)); WARN_LIST="$WARN_LIST\n    - $file" ;;
        2) CRITICAL_COUNT=$((CRITICAL_COUNT + 1)); CRITICAL_LIST="$CRITICAL_LIST\n    - $file" ;;
        *) WARN_COUNT=$((WARN_COUNT + 1)); WARN_LIST="$WARN_LIST\n    - $file" ;;
    esac
done <<< "$STAGED_FILES"

# ── Report summary ───────────────────────────────────────────────────────────
echo "" >&2
echo "── validation-agent pre-commit summary ──────────────────────────────" >&2
printf "  PASS    : %d file(s)\n" "$PASS_COUNT" >&2
printf "  WARNINGS: %d file(s)\n" "$WARN_COUNT" >&2
printf "  CRITICAL: %d file(s)\n" "$CRITICAL_COUNT" >&2

if [ "$WARN_COUNT" -gt 0 ]; then
    echo "" >&2
    echo "  [WARN] Files with warnings:" >&2
    printf "%b\n" "$WARN_LIST" >&2
    echo "" >&2

    # Prompt interactively — read from /dev/tty so it works even when git pipes stdin.
    # If /dev/tty is unavailable (CI, non-interactive), default to proceeding.
    if [ -e /dev/tty ]; then
        printf "  Continue with warnings? [y/N]: " >&2
        if read -r REPLY </dev/tty 2>/dev/null; then
            case "$REPLY" in
                [yY][eE][sS]|[yY]) ;;  # proceed
                *)
                    echo "  Commit aborted by user." >&2
                    echo "─────────────────────────────────────────────────────────────────────" >&2
                    exit 1
                    ;;
            esac
        else
            echo "" >&2
            echo "  [non-interactive] Warnings logged — commit proceeding automatically." >&2
        fi
    else
        echo "  [non-interactive] Warnings logged — commit proceeding automatically." >&2
    fi
fi

if [ "$CRITICAL_COUNT" -gt 0 ]; then
    echo "" >&2
    echo "  [BLOCKED] Files with critical issues — commit aborted:" >&2
    printf "%b\n" "$CRITICAL_LIST" >&2
    echo "" >&2
    echo "  Fix the issues above, re-stage the files, then commit again." >&2
    echo "  To bypass (not recommended): git commit --no-verify" >&2
    echo "─────────────────────────────────────────────────────────────────────" >&2
    exit 1
fi

echo "─────────────────────────────────────────────────────────────────────" >&2
exit 0
